<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Ne pas rewriter les fichiers/dossiers réels
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Routeur principal pour toutes les URLs
    # /article/titre-de-article → index.php?page=article&slug=titre-de-article
    RewriteRule ^article/([a-z0-9-]+)/?$ index.php?page=article&slug=$1 [QSA,L]

    # /categorie/nom-categorie → index.php?page=categorie&slug=nom-categorie
    RewriteRule ^categorie/([a-z0-9-]+)/?$ index.php?page=categorie&slug=$1 [QSA,L]

    # Accueil (racine) → index.php?page=home
    RewriteRule ^/?$ index.php?page=home [QSA,L]

</IfModule>

# Empêcher l'accès direct aux fichiers sensibles
<FilesMatch "\.(env|htaccess|htpasswd|ini|log|sh|sql)$">
    Require all denied
</FilesMatch>
